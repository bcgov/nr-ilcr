SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
LOG_LEVEL=INFO

# Local Oracle dev DB. Keep real local credentials in ignored .env only.
# The current scaffold is read-only in memory; these values are reserved for
# the first Oracle-backed repository slice.
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//<host>:1521/<service-name>
SPRING_DATASOURCE_USERNAME=<username>
